{
  "name": "hono-bun",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:cf": "wrangler dev",
    "build:serverless": "bun build ./src/index.ts --target=node --outfile=dist/index.js",
    "build:fc": "bun build ./src/index.ts --target=bun --outfile=dist/index.js",
    "deploy:cf": "wrangler deploy",
    "db:generate": "bunx --bun prisma generate",
    "db:push": "bunx --bun prisma db push",
    "db:migrate:dev": "bunx --bun prisma migrate dev",
    "db:migrate:deploy": "bunx --bun prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.8",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^7.0.0",
    "wrangler": "^4.0.0"
  }
}
